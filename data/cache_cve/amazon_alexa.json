        "id": "CVE-2023-33248",
        "sourceIdentifier": "cve@mitre.org",
        "published": "2023-05-24T22:15:09.207",
        "lastModified": "2025-01-16T16:15:29.630",
        "vulnStatus": "Modified",
        "cveTags": [],
        "descriptions": [
          {
            "lang": "en",
            "value": "Amazon Alexa software version 8960323972 on Echo Dot 2nd generation and 3rd generation devices potentially allows attackers to deliver security-relevant commands via an audio signal between 16 and 22 kHz (often outside the range of human adult hearing). Commands at these frequencies are essentially never spoken by authorized actors, but a substantial fraction of the commands are successful."
          }
        ],
